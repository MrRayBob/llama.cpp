# Copy this file to tools/server/.env and then edit the values.

# Optional host IP to publish on. Leave at 127.0.0.1 for local-only access.
TS_IP=127.0.0.1

# Optional Hugging Face token for router model downloads.
HF_TOKEN=

# Persistent Hugging Face cache on the host.
HF_CACHE_DIR=/home/your-user/.cache/huggingface

# Public API key exposed by the proxy.
PUBLIC_API_KEY=replace-with-a-long-random-public-key

# Proxy prompt-budget controls.
# The proxy now supports per-model overrides, so Gemma can expose 128k while the
# other two models stay capped for 32k contexts.
DEFAULT_HARD_PROMPT_CAP=32000
DEFAULT_COMPACTION_TRIGGER=24000

# Gemma 4 prompt budgeting.
# Set both values to 0 so the proxy does not rewrite or cap Gemma prompts.
# Backend ctx-size becomes the authority for this model.
GEMMA4_HARD_PROMPT_CAP=0
GEMMA4_COMPACTION_TRIGGER=0

# Mistral Nemo 12B prompt budgeting (32k ctx).
MISTRAL_NEMO_HARD_PROMPT_CAP=32000
MISTRAL_NEMO_COMPACTION_TRIGGER=24000

# Qwen Coder 7B prompt budgeting (32k ctx).
QWEN_CODER_HARD_PROMPT_CAP=32000
QWEN_CODER_COMPACTION_TRIGGER=24000

# Router runtime tuning.
# MODELS_MAX=1 keeps only one model loaded at a time.
MODELS_MAX=1

# Idle timeout before the loaded model is destroyed and VRAM is freed.
# 1800 seconds = 30 minutes.
SLEEP_IDLE_SECONDS=1800

# Shared router child defaults. These are rendered into /tmp/router-models.ini
# inside the backend container before llama-server starts.
DEFAULT_N_GPU_LAYERS=all
DEFAULT_PARALLEL=1
DEFAULT_BATCH_SIZE=1024
DEFAULT_UBATCH_SIZE=256
DEFAULT_FLASH_ATTN=true
DEFAULT_KV_CACHE_K_TYPE=q4_0
DEFAULT_KV_CACHE_V_TYPE=q8_0
DEFAULT_THREADS=
DEFAULT_THREADS_BATCH=

# Per-model router sections.
# Gemma 4 gets full 128k-class context and a larger batch/ubatch to improve
# long-prompt throughput.
GEMMA4_CTX_SIZE=131072
GEMMA4_BATCH_SIZE=2048
GEMMA4_UBATCH_SIZE=512
GEMMA4_THREADS=6
GEMMA4_THREADS_BATCH=12
GEMMA4_KV_CACHE_K_TYPE=q4_0
GEMMA4_KV_CACHE_V_TYPE=q4_0

# Mistral Nemo 12B remains 32k in the mixed router.
MISTRAL_NEMO_CTX_SIZE=32768

# Qwen Coder 7B remains 32k in the mixed router.
QWEN_CODER_CTX_SIZE=32768

# Backend-wide fit controls still apply to all child processes.
FIT_MODE=on
FIT_TARGET_MIB=256

# Router-exposed request model ids:
#   gemma4-4b-instruct
#   mistral-nemo-12b-instruct
#   qwen-coder-7b-instruct

# Copy this file to tools/server/.env and then edit the values.

# Tailscale or host IP to publish on. Use 127.0.0.1 if you only want local access.
TS_IP=127.0.0.1

# Hugging Face token used by the backend container for -hf model resolution.
HF_TOKEN=replace-with-your-hf-token

# Persistent Hugging Face cache on the host.
HF_CACHE_DIR=/home/your-user/.cache/huggingface

# Local template file to mount into both containers.
TEMPLATE_FILE=/home/your-user/ai/llama.cpp/models/templates/mistralai-Mistral-Nemo-Instruct-2407.jinja

# Backend model selector. If IQ3_M is unavailable for your chosen repo, change this to Q3_K_M.
LLAMA_HF_MODEL=bartowski/Mistral-Nemo-Instruct-2407-GGUF:IQ3_M

# Public model name exposed by the proxy.
MODEL_ALIAS=mistral-nemo-32k

# Separate keys so the backend stays private even from other containers on the Docker network.
BACKEND_API_KEY=replace-with-a-long-random-backend-key
PUBLIC_API_KEY=replace-with-a-long-random-public-key

# Backend/runtime tuning.
BACKEND_CTX_SIZE=32768
BACKEND_CTK=pq3_5
BACKEND_CTV=q8_0
N_GPU_LAYERS=auto

# Proxy compaction tuning.
COMPACTION_TRIGGER=24000
HARD_PROMPT_CAP=32000
RECENT_RAW_TAIL=8
FIRST_SUMMARY_TARGET=800
SECOND_SUMMARY_TARGET=400

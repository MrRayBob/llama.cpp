# Copy this file to tools/server/.env.gemma64 and then edit the values.

# Optional host IP to publish on. Set this to your Tailscale IP to expose over Tailscale.
TS_IP=127.0.0.1

# Published port for the Gemma-only proxy. Keep this different from docker-compose.proxy.yml.
HOST_PORT=8082

# Optional Hugging Face token for gated downloads.
HF_TOKEN=

# Persistent Hugging Face cache on the host.
HF_CACHE_DIR=/home/your-user/.cache/huggingface

# Public API key exposed by the proxy.
PUBLIC_API_KEY=replace-with-a-long-random-public-key

# Proxy prompt-budget controls. Keep these below CTX_SIZE.
HARD_PROMPT_CAP=62000
COMPACTION_TRIGGER=48000

# Single-model Gemma 4 runtime.
CTX_SIZE=65536
SLEEP_IDLE_SECONDS=1800
N_PARALLEL=1

# Speed-oriented prompt ingestion defaults for a dedicated profile.
N_BATCH=2048
N_UBATCH=512

# Threads tuned for the 6C/12T host used in recent logs.
THREADS=6
THREADS_BATCH=12

N_GPU_LAYERS=all
FIT_MODE=on
FIT_TARGET_MIB=128

# Mixed-router defaults favor q4_0/q8_0, but for a dedicated 64k Gemma profile
# q4_0/q4_0 leaves more headroom for the larger context window.
KV_CACHE_K_TYPE=q4_0
KV_CACHE_V_TYPE=q4_0
